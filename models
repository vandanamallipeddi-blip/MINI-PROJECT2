const mongoose = require("mongoose");

const foodSchema = new mongoose.Schema(
{
    foodName: {
        type: String,
        required: true
    },

    category: {
        type: String,
        required: true
    },

    price: {
        type: Number,
        required: true
    },

    quantity: {
        type: Number,
        required: true
    },

    restaurantName: {
        type: String,
        required: true
    },

    available: {
        type: Boolean,
        default: true
    }
},
{
    timestamps: true
}
);

module.exports = mongoose.model("Food", foodSchema);
